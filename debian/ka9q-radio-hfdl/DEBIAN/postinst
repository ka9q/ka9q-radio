case "$1" in
  configure)
    addgroup --system radio || true
    install -d -m 0775 -o radio -g radio /var/lib/hfdl
    /usr/bin/set_lo_multicast || true
    ;;
esac

# Automatically added by dh_installtmpfiles/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -x "$(command -v systemd-tmpfiles)" ]; then
		systemd-tmpfiles ${DPKG_ROOT:+--root="$DPKG_ROOT"} --create ka9q-radio-hfdl.conf || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if deb-systemd-helper debian-installed 'hfdl.service'; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper unmask 'hfdl.service' >/dev/null || true

		if deb-systemd-helper --quiet was-enabled 'hfdl.service'; then
			# Create new symlinks, if any.
			deb-systemd-helper enable 'hfdl.service' >/dev/null || true
		fi
	fi

	# Update the statefile to add new symlinks (if any), which need to be cleaned
	# up on purge. Also remove old symlinks.
	deb-systemd-helper update-state 'hfdl.service' >/dev/null || true
fi
# End automatically added section

