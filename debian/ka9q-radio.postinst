#!/bin/sh
set -e

do_reload() {
    systemctl daemon-reload || true
}

case "$1" in
    configure)
	bin=$(command -v radiod 2>/dev/null || true)
	if [ -n "$bin" ]; then
	    setcap cap_net_admin+ep "$bin" || true
	fi
	do_reload
	;;
    abort-upgrade|abort-remove|abort-deconfigure)
	do_reload
        ;;
esac

#DEBHELPER#

